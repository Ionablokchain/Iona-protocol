# Rust build artifacts
target/
**/*.rs.bk
Cargo.lock    # Uncomment if this is a binary; comment out if it's a library

# Fuzzing artifacts and corpus (generated by cargo-fuzz)
iona-fuzz/artifacts/
iona-fuzz/corpus/
# Or use wildcards if you prefer: **/artifacts/ **/corpus/

# IDE and OS files
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
.direnv/
.envrc

# Secrets and certificates
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx

# Runtime data (node storage, databases)
data/
data/**

# Local configuration overrides
deploy/configs/*local*.toml
config/*.local.toml

# Log files
*.log

# Coverage reports (if you generate them)
coverage/
lcov.info

# Python temporary files (if any scripts)
__pycache__/
*.pyc

# Optional: Docker-related files
.dockerignore
Dockerfile
docker-compose*.yml
