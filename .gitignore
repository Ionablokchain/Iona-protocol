# =============================================================================
# IONA — Git ignore file
# =============================================================================
# This file specifies intentionally untracked files that Git should ignore.
# It covers Rust builds, dependencies, runtime data, secrets, and IDE files.
# =============================================================================

# -----------------------------------------------------------------------------
# Rust build artifacts
# -----------------------------------------------------------------------------
/target/
**/*.rs.bk
Cargo.lock.user

# -----------------------------------------------------------------------------
# Environment and secrets (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
*.der
*.crt
id_rsa
id_ed25519
secrets/
private/
*.encrypted
*.gpg
*.age

# -----------------------------------------------------------------------------
# Runtime data and logs
# -----------------------------------------------------------------------------
/data/
/logs/
*.log
*.sqlite
*.db
*.wal
*.snap
*.pid
*.sock
*.dump
*.core
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Local configuration overrides
# -----------------------------------------------------------------------------
config.local.toml
config.*.local.toml
*.override.toml

# -----------------------------------------------------------------------------
# Editors and OS metadata
# -----------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.orig
*.rej

# -----------------------------------------------------------------------------
# Temporary test outputs
# -----------------------------------------------------------------------------
test-results/
coverage/
*.profraw
*.profdata

# -----------------------------------------------------------------------------
# Node / dependency directories (if any)
# -----------------------------------------------------------------------------
node_modules/
dist/
build/

# -----------------------------------------------------------------------------
# Archive files (optional)
# -----------------------------------------------------------------------------
*.zip
*.tar
*.gz
*.xz
*.bz2
