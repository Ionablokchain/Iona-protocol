use serde::{Deserialize, Serialize};
use std::collections::HashMap;
use thiserror::Error;

#[derive(Debug, Error)]
pub enum GenesisError {
    #[error("invalid checksum: expected {expected}, got {actual}")]
    InvalidChecksum { expected: String, actual: String },
    #[error("validator seed {seed} already used")]
    DuplicateValidatorSeed(u64),
    #[error("validator stake {stake} below minimum {min}")]
    StakeBelowMinimum { stake: u64, min: u64 },
    #[error("chain id mismatch: expected {expected}, got {actual}")]
    ChainIdMismatch { expected: u64, actual: u64 },
    #[error("field missing: {0}")]
    MissingField(&'static str),
    #[error("invalid value for {field}: {reason}")]
    InvalidValue { field: &'static str, reason: String },
    #[error("IO error: {0}")]
    Io(#[from] std::io::Error),
    #[error("JSON error: {0}")]
    Json(#[from] serde_json::Error),
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Genesis {
    pub chain: ChainConfig,
    pub consensus: ConsensusConfig,
    pub validators: Vec<ValidatorEntry>,
    pub accounts: Vec<AccountEntry>,
    pub economics: EconomicsConfig,
    pub governance: GovernanceConfig,
    pub slashing: SlashingConfig,
    pub network: NetworkConfig,
    pub upgrades: Vec<UpgradeEntry>,
    pub metadata: Metadata,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ChainConfig {
    pub id: u64,
    pub name: String,
    pub genesis_time: u64,
    pub genesis_time_human: String,
    pub protocol_version: u32,
    pub schema_version: u32,
    pub checksum: Option<String>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ValidatorEntry {
    pub seed: u64,
    pub role: String, // "producer" or "follower"
    pub stake: u64,
    pub label: String,
    pub address: Option<String>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct AccountEntry {
    pub address: String,
    pub balance: u64,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct EconomicsConfig {
    pub base_inflation_bps: u32,
    pub treasury_bps: u32,
    pub min_stake: u64,
    pub unbonding_epochs: u32,
    pub epoch_length: u64,
    pub max_validators: u32,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct GovernanceConfig {
    pub min_deposit: u64,
    pub voting_epochs: u64,
    pub quorum_bps: u32,
    pub threshold_bps: u32,
    pub veto_bps: u32,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct SlashingConfig {
    pub double_sign_slash_bps: u32,
    pub downtime_slash_bps: u32,
    pub min_stake_after_slash: u64,
    pub unjail_delay_blocks: u64,
    pub downtime_window: u64,
    pub downtime_min_signed: u64,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct NetworkConfig {
    pub bootnodes: Vec<String>,
    pub enable_mdns: bool,
    pub enable_kad: bool,
    pub max_connections_per_ip: usize,
    pub max_connections: usize,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct UpgradeEntry {
    pub protocol_version: u32,
    pub activation_height: u64,
    pub grace_blocks: u64,
    pub description: Option<String>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Metadata {
    pub description: String,
    pub contact: String,
    pub git_rev: String,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ConsensusConfig {
    pub propose_timeout_ms: u64,
    pub prevote_timeout_ms: u64,
    pub precommit_timeout_ms: u64,
    pub max_txs_per_block: u32,
    pub gas_target: u64,
    pub fast_quorum: bool,
    pub initial_base_fee: u64,
    pub min_validator_count: u32,
    pub max_rounds: u32,
}

impl Genesis {
    pub fn validate(&self, expected_chain_id: Option<u64>) -> Result<(), GenesisError> {
        // Chain ID
        if let Some(expected) = expected_chain_id {
            if self.chain.id != expected {
                return Err(GenesisError::ChainIdMismatch {
                    expected,
                    actual: self.chain.id,
                });
            }
        }
        // Check schema version
        if self.chain.schema_version != 5 {
            return Err(GenesisError::InvalidValue {
                field: "chain.schema_version",
                reason: format!("expected 5, got {}", self.chain.schema_version),
            });
        }
        // Validator seeds unique
        let mut seen = std::collections::HashSet::new();
        for v in &self.validators {
            if !seen.insert(v.seed) {
                return Err(GenesisError::DuplicateValidatorSeed(v.seed));
            }
            if v.role != "producer" && v.role != "follower" {
                return Err(GenesisError::InvalidValue {
                    field: "validator.role",
                    reason: format!("invalid role '{}'", v.role),
                });
            }
            if v.role == "producer" && v.stake < self.economics.min_stake {
                return Err(GenesisError::StakeBelowMinimum {
                    stake: v.stake,
                    min: self.economics.min_stake,
                });
            }
        }
        // Economic sanity
        if self.economics.base_inflation_bps > 10_000 {
            return Err(GenesisError::InvalidValue {
                field: "base_inflation_bps",
                reason: "must be ≤ 10_000".to_string(),
            });
        }
        if self.economics.treasury_bps > 10_000 {
            return Err(GenesisError::InvalidValue {
                field: "treasury_bps",
                reason: "must be ≤ 10_000".to_string(),
            });
        }
        // Governance
        if self.governance.quorum_bps > 10_000
            || self.governance.threshold_bps > 10_000
            || self.governance.veto_bps > 10_000
        {
            return Err(GenesisError::InvalidValue {
                field: "governance.*bps",
                reason: "basis points must be ≤ 10_000".to_string(),
            });
        }
        // Checksum can be verified by the caller (we don't have the raw bytes here)
        Ok(())
    }

    /// Compute SHA‑256 of the canonical JSON (without the `checksum` field)
    pub fn compute_checksum(&self) -> String {
        // In production, serialize to a canonical JSON string (sorted keys, no whitespace)
        // and hash with SHA‑256. This is a placeholder.
        unimplemented!("use a canonical JSON serializer")
    }
}
