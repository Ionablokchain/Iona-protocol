[Unit]
Description=IONA Validator 1 (Follower / Indexer)
After=network-online.target
Wants=network-online.target
# Start after producers are likely up
After=iona-val2.service iona-val3.service iona-val4.service

[Service]
Type=simple
User=iona
Group=iona
ExecStart=/usr/local/bin/iona-node --config /etc/iona/val1.toml
Restart=on-failure
RestartSec=2
TimeoutStopSec=30

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/iona/val1
LimitNOFILE=1048576

# Environment
Environment=RUST_LOG=info
EnvironmentFile=-/etc/iona/val1.env

[Install]
WantedBy=multi-user.target
