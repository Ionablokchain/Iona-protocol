{
  "name": "iona-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for interacting with Iona blockchain nodes",
  "keywords": ["iona", "blockchain", "sdk", "typescript", "client"],
  "homepage": "https://github.com/Ionablokchain/Iona-protocol/tree/main/sdk/typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ionablokchain/Iona-protocol.git",
    "directory": "sdk/typescript"
  },
  "license": "Apache-2.0",
  "author": "Iona Blockchain Contributors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "gen": "node scripts/generate.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "prepare": "npm run build",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "cross-fetch": "^4.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
