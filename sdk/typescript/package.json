{
  "name": "@ionachain/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the IONA blockchain — query nodes, submit transactions, and manage wallets",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:cjs",
    "build:cjs": "esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:axios",
    "build:watch": "tsc -p tsconfig.json --watch",
    "gen": "node scripts/generate.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "docs": "typedoc --out docs/api src/index.ts",
    "prepublishOnly": "npm run build && npm run test && npm run lint",
    "prepack": "npm run build",
    "clean": "rm -rf dist/ docs/ coverage/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ionachain/iona-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ionachain/iona-sdk/issues"
  },
  "homepage": "https://docs.iona.network/sdk",
  "keywords": [
    "iona",
    "blockchain",
    "sdk",
    "typescript",
    "rpc",
    "validator"
  ],
  "author": "IONA Foundation <dev@iona.network>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.24.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typedoc": "^0.27.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
